{
  "name": "finance-hub",
  "version": "2.0.0",
  "private": true,
  "description": "Feldart Finance Hub 2.0 — Fastify + React + Postgres + BullMQ",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/server/server.ts",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "start": "node dist/server/server.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/static": "^8.0.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@shopify/shopify-api": "^11.5.0",
    "@tanstack/react-query": "^5.59.16",
    "@tanstack/react-router": "^1.81.5",
    "arctic": "^3.0.0",
    "argon2": "^0.41.1",
    "axios": "^1.7.7",
    "bullmq": "^5.21.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "googleapis": "^144.0.0",
    "intuit-oauth": "^4.2.0",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.453.0",
    "nanoid": "^5.0.7",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-devtools": "^1.81.5",
    "@types/node": "^22.7.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "drizzle-kit": "^0.28.0",
    "pino-pretty": "^11.3.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.3"
  }
}
