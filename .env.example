# --- Runtime ---
NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgres://finance:finance@localhost:5432/finance_hub

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379

# --- Crypto ---
# 32-byte (64 hex chars) AES-256 key for encrypting OAuth tokens at rest
CRYPTO_KEY=
# Secret used to sign session cookies
COOKIE_SECRET=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- QuickBooks ---
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REALM_ID=
QB_REDIRECT_URI=http://localhost:3000/oauth/callback/quickbooks

# --- Google / Gmail ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Shopify ---
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_API_VERSION=2025-01

# --- Monday (optional mirror, can disable) ---
MONDAY_API_TOKEN=
MONDAY_ENABLED=false

# --- Observability ---
SENTRY_DSN=
