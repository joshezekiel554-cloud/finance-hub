# --- Runtime ---
NODE_ENV=development
# orders.feldart.com runs on 3000 — finance hub uses 3001
PORT=3001
PUBLIC_URL=http://localhost:3001

# --- Database (MySQL 8) ---
DATABASE_URL=mysql://feldart_app:CHANGEME@localhost:3306/feldart_finance

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379

# --- Auth.js v5 ---
# Generated via `openssl rand -base64 32` — used to sign session cookies + CSRF tokens
AUTH_SECRET=
# Public origin Auth.js sees in callbacks (dev: http://localhost:3001, prod: https://finance.feldart.com)
AUTH_URL=http://localhost:3001
# Google Cloud OAuth client. Can reuse the orders.feldart.com Google project's
# client (add http://localhost:3001/api/auth/callback/google + the prod URL to
# its authorized redirect URIs), or provision a fresh one — either works.
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# --- Crypto ---
# 32-byte (64 hex chars) AES-256-GCM key for encrypting integration OAuth tokens at rest
# (QuickBooks, Gmail, Shopify). Independent from AUTH_SECRET — different purpose.
CRYPTO_KEY=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- QuickBooks ---
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REALM_ID=
QB_REDIRECT_URI=http://localhost:3001/oauth/callback/quickbooks

# --- Google / Gmail (separate from AUTH_GOOGLE_* above — these are for the
#      shared mailbox we read/send through, not user login) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Shopify ---
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_API_VERSION=2025-01

# --- Monday (optional mirror, can disable) ---
MONDAY_API_TOKEN=
MONDAY_ENABLED=false

# --- Observability ---
SENTRY_DSN=
