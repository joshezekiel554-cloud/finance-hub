# --- Runtime ---
NODE_ENV=development
# orders.feldart.com runs on 3000 — finance hub uses 3001
PORT=3001
PUBLIC_URL=http://localhost:3001

# --- Database (MySQL 8) ---
DATABASE_URL=mysql://feldart_app:CHANGEME@localhost:3306/feldart_finance

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379

# --- Auth.js v5 ---
# Generated via `openssl rand -base64 32` — used to sign session cookies + CSRF tokens
AUTH_SECRET=
# Public origin Auth.js sees in callbacks (dev: http://localhost:3001, prod: https://finance.feldart.com)
AUTH_URL=http://localhost:3001
# Google Cloud OAuth client. Can reuse the orders.feldart.com Google project's
# client (add http://localhost:3001/api/auth/callback/google + the prod URL to
# its authorized redirect URIs), or provision a fresh one — either works.
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
# Comma-separated allow-list of emails permitted to sign in. Sign-in attempts
# from any other email are rejected by the signIn callback before account
# creation. Empty in dev is allowed (server logs a warning) — production must
# set this to at least one email.
# Example: ALLOWED_EMAILS=joshua@feldart.com,teammate@example.com
ALLOWED_EMAILS=

# Comma-separated allow-list of emails granted ADMIN-only privileges.
# Distinct from ALLOWED_EMAILS — that's the sign-in gate; this is the
# role gate within the app. Used to authorise destructive routes like
# RMA forceStatus and hard delete. Empty = nobody is admin (those routes
# 403 for everyone). Subset of ALLOWED_EMAILS in practice.
# Example: ADMIN_EMAILS=joshua@feldart.com
ADMIN_EMAILS=

# --- Crypto ---
# 32-byte (64 hex chars) AES-256-GCM key for encrypting integration OAuth tokens at rest
# (QuickBooks, Gmail, Shopify). Independent from AUTH_SECRET — different purpose.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRYPTO_KEY=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- QuickBooks ---
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REALM_ID=
QB_REDIRECT_URI=http://localhost:3001/oauth/callback/quickbooks

# --- Google / Gmail (separate from AUTH_GOOGLE_* above — these are for the
#      shared mailbox we read/send through, not user login) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Shopify ---
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_API_VERSION=2025-01

# --- Monday (optional mirror, can disable) ---
MONDAY_API_TOKEN=
MONDAY_ENABLED=false

# Returns/RMA configuration (drive_root_folder_id, warehouse_team_email,
# rma_shipping_fee_item_id, rma_restocking_fee_item_id) lives in
# app_settings — set those via the /settings page after first boot,
# not via env. Operator can change them without a redeploy.

# --- Shared tasks (finance → inbox service API) ---
# The unified-tasks feature flips the direction: finance is a CLIENT of the
# inbox task engine. Bearer token sent on every call into inbox's /api/svc/*.
# Operator generates with `openssl rand -hex 32` and sets the SAME value in
# both apps' env (it is inbox's service token, from finance's perspective).
INBOX_SERVICE_TOKEN=
# Base URL of the sibling Inbox service. Same VPS → loopback (mirror of
# inbox's FINANCE_BASE_URL=127.0.0.1:3001).
INBOX_BASE_URL=http://127.0.0.1:3002
# PUBLIC origin of the inbox app — used as the iframe src for the embedded tasks
# board (the browser loads it). Distinct from INBOX_BASE_URL (loopback, S2S only).
INBOX_PUBLIC_URL=https://inbox.feldart.com
# HMAC secret to mint the short-lived embedded-board viewer token (used in M1).
# `openssl rand -hex 32`. Must be 32+ chars.
TASKS_EMBED_SIGNING_SECRET=

# --- Observability ---
SENTRY_DSN=

# Vocatech phone/SMS integration. Provision via Vocatech support.
VOCATECH_API_KEY=
VOCATECH_WEBHOOK_SECRET=
# Phone number registered to your Vocatech tenant. Required for outbound
# SMS (the `from` field on POST /messages). 10-digit US or E.164.
VOCATECH_FROM_NUMBER=
